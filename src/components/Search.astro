---
import { useTranslations } from '../utils/i18n';

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div id="search-container" class="relative">
  <button
    id="search-button"
    class="p-2 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors"
    aria-label={t('search.placeholder')}
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </button>

  <div
    id="search-modal"
    class="hidden fixed inset-0 z-[60] overflow-y-auto bg-gray-900/50 backdrop-blur-sm p-4 pt-[10vh]"
  >
    <div class="max-w-2xl mx-auto bg-white dark:bg-gray-800 rounded-xl shadow-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex items-center gap-3">
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder={t('search.placeholder')}
          class="flex-1 bg-transparent border-none focus:ring-0 text-lg text-gray-900 dark:text-gray-100 placeholder-gray-400"
          autocomplete="off"
        />
        <kbd class="hidden sm:inline-block px-1.5 py-0.5 border border-gray-300 dark:border-gray-600 rounded text-xs text-gray-500 bg-gray-50 dark:bg-gray-700">ESC</kbd>
      </div>
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <!-- Results will be injected here -->
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ lang, noResultsText: t('search.noResults') }}>
  let pagefind;

  const searchButton = document.getElementById('search-button');
  const searchModal = document.getElementById('search-modal');
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');

  const openSearch = async () => {
    searchModal.classList.remove('hidden');
    searchInput.focus();
    
    if (!pagefind) {
      pagefind = await import("/_pagefind/pagefind.js");
      await pagefind.options({
        primaryColor: "#3b82f6",
      });
    }
  };

  const closeSearch = () => {
    searchModal.classList.add('hidden');
  };

  searchButton?.addEventListener('click', openSearch);

  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) closeSearch();
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape') closeSearch();
  });

  searchInput?.addEventListener('input', async (e) => {
    const query = e.target.value;
    if (!query) {
      searchResults.innerHTML = '';
      return;
    }

    const search = await pagefind.search(query, {
      filters: { lang: lang }
    });
    
    if (search.results.length === 0) {
      searchResults.innerHTML = `<div class="p-4 text-center text-gray-500">${noResultsText}</div>`;
      return;
    }

    searchResults.innerHTML = '';
    for (const result of search.results.slice(0, 8)) {
      const data = await result.data();
      const div = document.createElement('a');
      div.href = data.url;
      div.className = 'block p-4 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors group';
      div.innerHTML = `
        <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-blue-500 transition-colors">${data.meta.title}</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 line-clamp-2">${data.excerpt}</p>
      `;
      searchResults.appendChild(div);
    }
  });
</script>
