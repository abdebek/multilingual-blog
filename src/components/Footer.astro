---
import { useTranslations } from '../utils/i18n';
import { getLangFromUrl } from '../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const socialLinks = [
  { 
    href: 'https://twitter.com', 
    icon: 'x', 
    label: 'social.twitter', 
    path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z'
  },
  { 
    href: 'https://facebook.com', 
    icon: 'facebook', 
    label: 'social.facebook', 
    path: 'M14 13.5h2.5l1-4H14v-2c0-1.03 0-2 2-2h1.5V2.14c-.326-.043-1.557-.14-2.857-.14C11.928 2 10 3.657 10 6.7v2.8H7v4h3V22h4v-8.5z'
  },
  { 
    href: 'https://instagram.com', 
    icon: 'instagram', 
    label: 'social.instagram', 
    path: 'M12 2c2.717 0 3.056.01 4.122.06 1.065.05 1.79.217 2.428.465.66.254 1.216.598 1.772 1.153a4.908 4.908 0 0 1 1.153 1.772c.247.637.415 1.363.465 2.428.047 1.066.06 1.405.06 4.122 0 2.717-.01 3.056-.06 4.122-.05 1.065-.218 1.79-.465 2.428a4.883 4.883 0 0 1-1.153 1.772 4.915 4.915 0 0 1-1.772 1.153c-.637.247-1.363.415-2.428.465-1.066.047-1.405.06-4.122.06-2.717 0-3.056-.01-4.122-.06-1.065-.05-1.79-.218-2.428-.465a4.89 4.89 0 0 1-1.772-1.153 4.904 4.904 0 0 1-1.153-1.772c-.248-.637-.415-1.363-.465-2.428C2.013 15.056 2 14.717 2 12c0-2.717.01-3.056.06-4.122.05-1.066.217-1.79.465-2.428a4.88 4.88 0 0 1 1.153-1.772A4.897 4.897 0 0 1 5.45 2.525c.638-.248 1.362-.415 2.428-.465C8.944 2.013 9.283 2 12 2zm0 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm6.5-.25a1.25 1.25 0 1 0-2.5 0 1.25 1.25 0 0 0 2.5 0zM12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6z'
  }
];

const footerLinks = [
  { href: `/${lang}/privacy-policy`, label: t('footer.privacyPolicy') },
  { href: `/${lang}/about`, label: t('nav.about') },
  { href: `/${lang}/contact`, label: t('nav.contact') },
];

const currentYear = new Date().getFullYear();
---
<footer class:list={[
  'bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800',
  'px-4 py-12 md:py-16 mt-auto',
  lang === 'ar' ? 'font-cairo text-right' : 'text-left'
]}>
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
    <!-- Tagline Section -->
    <div class="lg:col-span-2">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 tracking-tight">{t('footer.tagline')}</h1>
      <p class="text-gray-600 dark:text-gray-400 max-w-md leading-relaxed">{t('footer.description')}</p>
    </div>

    <!-- Footer Links -->
    <div>
      <h2 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-6">{t('footer.linksTitle')}</h2>
      <ul class="space-y-4">
        {footerLinks.map(({ href, label }) => (
          <li>
            <a href={href} class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium">
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Social Links -->
    <div>
      <h2 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-6">{t('footer.followUs')}</h2>
      <div class={`flex ${lang === 'ar' ? 'space-x-reverse space-x-5' : 'space-x-5'}`}>
        {socialLinks.map(({ href, path, label }) => (
          <a href={href} class="text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors transform hover:-translate-y-1 duration-200" aria-label={t(label)}>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d={path} />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col md:flex-row justify-between items-center text-sm text-gray-500 dark:text-gray-500">
    <p>&copy; {currentYear} {t('site.title')}. {t('footer.rightsReserved')}</p>
    <p class="mt-2 md:mt-0 flex items-center">
      {t('footer.madeWithLove')}
      <span class="text-red-500 mx-1">❤</span>
    </p>
  </div>
</footer>