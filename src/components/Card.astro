---
interface Props {
	title: string;
	body: string;
	href: string;
}

const { href, title, body } = Astro.props;
---

<li class="link-card list-none flex p-[1px] bg-gray-800 dark:bg-gray-900 bg-none bg-[length:400%] rounded-lg bg-[position:100%] transition-[background-position] duration-600 ease-[cubic-bezier(0.22,1,0.36,1)] shadow-[inset_0_0_0_1px_rgba(255,255,255,0.1)]">
	<a 
		href={href} 
		class="w-full no-underline leading-[1.4] p-[calc(1.5rem-1px)] rounded-lg text-white bg-gray-800 dark:bg-gray-900 opacity-80 transition-opacity hover:opacity-100"
	>
		<h2 class="m-0 text-[1.25rem] transition-colors duration-600 ease-[cubic-bezier(0.22,1,0.36,1)] hover:text-accent-light">
			{title}
			<span>&rarr;</span>
		</h2>
		<p class="mt-[0.5rem] mb-0">
			{body}
		</p>
	</a>
</li>
