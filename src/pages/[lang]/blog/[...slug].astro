---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl } from '../../../utils/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: {
      lang: post.data.lang,
      slug: post.slug.split('/').pop(),
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const lang = getLangFromUrl(Astro.url);
---

<Layout title={post.data.title}>
  <main class="container mx-auto max-w-4xl px-4 py-8">
    <article class="prose lg:prose-xl dark:prose-invert mx-auto">
      {post.data.image && (
        <Image 
          src={post.data.image} 
          alt={post.data.title} 
          width={800}
          height={450}
          class="w-full rounded-xl shadow-lg mb-8"
        />
      )}
      <h1>{post.data.title}</h1>
      <time datetime={post.data.pubDate.toISOString()} class="text-gray-500 dark:text-gray-400 block mb-8">
        {post.data.pubDate.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <Content />
    </article>
  </main>
</Layout>
