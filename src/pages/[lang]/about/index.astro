---
import Layout from '../../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../../utils/i18n';
import { languages } from '../../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const team = [
  {
    name: t('about.team.sarah.name'),
    role: t('about.team.sarah'),
    color: 'from-blue-400 to-blue-600',
    bio: t('about.team.sarah.bio')
  },
  {
    name: t('about.team.ahmed.name'),
    role: t('about.team.ahmed'),
    color: 'from-emerald-400 to-emerald-600',
    bio: t('about.team.ahmed.bio')
  }
];
---

<Layout title={t('about.title')}>
  <main class="container mx-auto px-4 py-12 md:py-20 w-full max-w-5xl space-y-24">
    
    <!-- Story Section -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center border-b border-gray-100 dark:border-gray-800 pb-24">
      <div class="space-y-6">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white tracking-tight flex items-center gap-3">
          <span class="w-8 h-1 bg-primary-500 rounded-full"></span>
          {t('about.story.title')}
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
          {t('about.story.content')}
        </p>
        <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
          {t('about.story.extra')}
        </p>
      </div>
      <div class="bg-gray-100 dark:bg-gray-800 rounded-3xl p-12 aspect-square flex items-center justify-center relative overflow-hidden group border border-gray-200 dark:border-gray-700 shadow-inner">
         <div class="absolute inset-0 opacity-10 dark:opacity-20 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-from)_0%,_transparent_70%)] from-primary-500"></div>
         <svg class="w-48 h-48 text-primary-500/40 relative z-10 transition-transform duration-700 group-hover:scale-110 group-hover:rotate-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" stroke-dasharray="3 3" />
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            <path d="M2 12h20" opacity="0.5" />
            <circle cx="12" cy="12" r="3" fill="currentColor" fill-opacity="0.2" />
            <circle cx="12" cy="12" r="0.5" fill="currentColor" />
         </svg>
      </div>
    </section>

    <!-- Mission Section -->
    <section class="bg-primary-600 rounded-[2.5rem] p-10 md:p-16 text-white shadow-xl relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-500 to-primary-700"></div>
      <div class="relative z-10 max-w-3xl">
        <h2 class="text-3xl md:text-4xl font-extrabold mb-6 tracking-tight">
          {t('about.mission.title')}
        </h2>
        <p class="text-xl md:text-2xl text-primary-50 leading-relaxed">
          {t('about.mission.content')}
        </p>
      </div>
    </section>

    <!-- Team Section -->
    <section>
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white tracking-tight mb-4">
          {t('about.team.title')}
        </h2>
        <p class="text-gray-500 dark:text-gray-400">{t('about.team.description')}</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {team.map(member => (
          <div class="group bg-white dark:bg-gray-800 rounded-3xl p-8 border border-gray-100 dark:border-gray-700 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8">
              <div class={`w-20 h-20 sm:w-24 sm:h-24 rounded-2xl bg-gradient-to-br ${member.color} flex items-center justify-center shadow-lg transform group-hover:rotate-3 transition-transform duration-500`}>
                <svg class="w-10 h-10 sm:w-12 sm:h-12 text-white/90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <div class="space-y-3 text-center sm:text-left">
                <div>
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">{member.name}</h3>
                  <p class="text-primary-600 dark:text-primary-400 font-bold text-xs uppercase tracking-wider">{member.role}</p>
                </div>
                <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-sm">
                  {member.bio}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="text-center py-12 border-t border-gray-100 dark:border-gray-800">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">{t('about.join.title')}</h2>
      <a href={`/${lang}/contact`} class="inline-flex items-center gap-2 px-10 py-4 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-full font-bold hover:bg-primary-600 dark:hover:bg-primary-400 hover:text-white transition-all shadow-xl hover:-translate-y-1">
        {t('about.join.button')}
        <svg class="ml-1 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
    </section>

  </main>
</Layout>
