---
import { useTranslations } from '../utils/i18n';

const { lang, mobile = false } = Astro.props;
const t = useTranslations(lang);
const isDev = import.meta.env.DEV;
---

<div id="search-container" class="relative">
  {mobile ? (
    <button
      id="search-button-mobile"
      type="button"
      class="p-2.5 text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-xl transition-all"
      aria-label={t('search.placeholder')}
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </button>
  ) : (
    <button
      id="search-button-desktop"
      type="button"
      class="flex items-center gap-3 px-4 py-2 w-48 lg:w-64 text-left text-sm text-gray-400 bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-primary-500/50 dark:hover:border-primary-500/50 hover:bg-white dark:hover:bg-gray-800 transition-all group"
    >
    >
      <svg class="w-4 h-4 text-gray-400 group-hover:text-primary-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <span class="flex-1">{t('search.placeholder')}</span>
      <kbd class="hidden lg:inline-flex items-center gap-1 px-1.5 py-0.5 text-[10px] font-medium text-gray-400 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded">
        <span class="text-xs">⌘</span>K
      </kbd>
    </button>
  )}

  <div
    id="search-modal"
    class="hidden fixed inset-0 z-[110] overflow-y-auto bg-gray-950/60 backdrop-blur-sm p-4 pt-[10vh] sm:pt-[15vh]"
  >
    <div 
      id="search-modal-content"
      class="max-w-2xl mx-auto bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-800 overflow-hidden transform transition-all"
    >
      <div class="p-5 border-b border-gray-100 dark:border-gray-800 flex items-center gap-4">
        <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder={t('search.placeholder')}
          class="flex-1 bg-transparent border-none focus:ring-0 text-xl text-gray-900 dark:text-white placeholder-gray-400 outline-none"
          autocomplete="off"
        />
        <button id="close-search" type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 p-1">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <div id="search-results" class="max-h-[50vh] overflow-y-auto p-3 space-y-1">
        <!-- Results will be injected here -->
        {isDev && (
          <div class="p-8 text-center">
            <div class="inline-flex p-3 rounded-full bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">{t('search.devMode')}</h3>
            <p class="text-gray-500 dark:text-gray-400 text-sm max-w-sm mx-auto leading-relaxed">
              {t('search.devModeDesc')}
            </p>
          </div>
        )}
      </div>

      <div class="px-5 py-3 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 flex justify-between items-center text-[11px] text-gray-400 font-medium">
        <div class="flex items-center gap-4">
          <span class="flex items-center gap-1.5"><kbd class="px-1 py-0.5 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded shadow-sm">↵</kbd> {t('search.select')}</span>
          <span class="flex items-center gap-1.5"><kbd class="px-1 py-0.5 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded shadow-sm">↑↓</kbd> {t('search.navigate')}</span>
        </div>
        <div class="flex items-center gap-1">
          {t('search.powered')} <span class="text-primary-500 font-bold">Pagefind</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ lang, noResultsText: t('search.noResults') }}>
  let pagefind;

  const searchButtons = [
    document.getElementById('search-button-desktop'),
    document.getElementById('search-button-mobile')
  ].filter(Boolean);
  
  const searchModal = document.getElementById('search-modal');
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const closeButton = document.getElementById('close-search');

  // Move modal to body to avoid stacking context issues
  if (searchModal && searchModal.parentElement !== document.body) {
    document.body.appendChild(searchModal);
  }

  const openSearch = async () => {
    if (!searchModal) return;
    searchModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    searchInput.focus();
    
    if (!pagefind) {
      try {
        // Correct path for Pagefind index
        pagefind = await import("/pagefind/pagefind.js");
        await pagefind.options({
          primaryColor: "#3b82f6",
        });
      } catch (e) {
        // Search not available (e.g. in dev mode or before build)
      }
    }
  };

  const closeSearch = () => {
    searchModal.classList.add('hidden');
    document.body.style.overflow = '';
  };

  searchButtons.forEach(btn => btn?.addEventListener('click', openSearch));
  closeButton?.addEventListener('click', closeSearch);

  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) closeSearch();
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape') closeSearch();
  });

  let debounceTimer;
  searchInput?.addEventListener('input', async (e) => {
    const query = e.target.value;
    clearTimeout(debounceTimer);
    
    if (!query) {
      searchResults.innerHTML = '';
      return;
    }

    debounceTimer = setTimeout(async () => {
      if (!pagefind) return;

      // Filter by language based on the HTML lang attribute or metadata
      const search = await pagefind.search(query);
      
      // Filter results manually to ensure 100% accuracy with multilingual content
      const filteredResults = [];
      for (const result of search.results) {
        const data = await result.data();
        if (data.url.includes(`/${lang}/`)) {
          filteredResults.push(data);
        }
        if (filteredResults.length >= 6) break;
      }
      
      if (filteredResults.length === 0) {
        searchResults.innerHTML = `
          <div class="p-12 text-center">
            <p class="text-gray-500 dark:text-gray-400 font-medium">${noResultsText}</p>
          </div>
        `;
        return;
      }

      searchResults.innerHTML = '';
      for (const data of filteredResults) {
        const div = document.createElement('a');
        div.href = data.url;
        div.className = 'block p-4 hover:bg-primary-50 dark:hover:bg-primary-900/20 rounded-xl transition-all group border border-transparent hover:border-primary-100 dark:hover:border-primary-800';
        div.innerHTML = `
          <div class="flex items-center justify-between gap-4">
            <div class="flex-1">
              <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">${data.meta.title}</h3>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1.5 line-clamp-2 leading-relaxed">${data.excerpt}</p>
            </div>
            <div class="hidden sm:block text-primary-500 opacity-0 group-hover:opacity-100 transition-opacity">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </div>
          </div>
        `;
        searchResults.appendChild(div);
      }
    }, 150);
  });
</script>
