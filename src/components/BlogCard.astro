---
interface Props {
  title: string;
  description: string;
  url: string;
  pubDate: Date;
}

const { title, description, url, pubDate } = Astro.props;
---

<article class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
  <a href={url} class="block p-6">
    <h2 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">{title}</h2>
    <p class="text-gray-600 dark:text-gray-300 mb-4">    
      {description}
    </p>
    <time datetime={pubDate.toISOString()} class="text-sm text-gray-500 dark:text-gray-400">
      {pubDate.toLocaleDateString()}
    </time>
  </a>
</article>