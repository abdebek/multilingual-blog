---
import Layout from '../../../layouts/Layout.astro';
import AboutContent from '../../../components/AboutContent.astro';
import { getLangFromUrl, useTranslations } from '../../../utils/i18n';
import { languages } from '../../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('nav.about')}>
  <main class="max-w-5xl mx-5 sm:mx-8 lg:mx-12 xl:mx-24 px-4 sm:px-6 py-8">
    <h1 class="text-4xl font-bold text-center mb-8">{t('nav.about')}</h1>
    <AboutContent lang={lang} />
  </main>
</Layout>