---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  url: string;
  pubDate: string | Date;
  image?: any;
  lang: string;
}

const { title, description, url, pubDate, image, lang } = Astro.props;
const formattedPubDate = new Date(pubDate);
---

<article class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow flex flex-col h-full">
  <a href={url} class="flex flex-col h-full">
    {image ? (
      <div class="aspect-video w-full overflow-hidden bg-gray-100 dark:bg-gray-700">
        <Image 
          src={image} 
          alt={title} 
          width={400}
          height={225}
          class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
        />
      </div>
    ) : (
      <div class="aspect-video w-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
        <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
    <div class="p-6 flex flex-col flex-grow">
      <h2 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100 line-clamp-2">{title}</h2>
      <p class="text-gray-600 dark:text-gray-300 mb-4 line-clamp-3 flex-grow">    
        {description}
      </p>
      <time datetime={formattedPubDate.toISOString()} class="text-sm text-gray-500 dark:text-gray-400 mt-auto">
        {formattedPubDate.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </div>
  </a>
</article>
