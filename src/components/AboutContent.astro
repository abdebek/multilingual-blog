---
import { useTranslations } from '../utils/i18n';

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="max-w-3xl mx-auto prose dark:prose-invert">
  <h2 class="text-2xl font-bold mb-4">{t('about.story.title')}</h2>
  <p class="mb-6">{t('about.story.content')}</p>

  <h2 class="text-2xl font-bold mb-4">{t('about.mission.title')}</h2>
  <p class="mb-6">{t('about.mission.content')}</p>

  <h2 class="text-2xl font-bold mb-4">{t('about.team.title')}</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
    <div class="bg-white dark:bg-gray-800 p-4 rounded-lg shadow">
      <h3 class="text-xl font-semibold">Sarah Johnson</h3>
      <p class="text-gray-600 dark:text-gray-300">{t('about.team.sarah')}</p>
    </div>
    <div class="bg-white dark:bg-gray-800 p-4 rounded-lg shadow">
      <h3 class="text-xl font-semibold">Ahmed Hassan</h3>
      <p class="text-gray-600 dark:text-gray-300">{t('about.team.ahmed')}</p>
    </div>
  </div>
</div>